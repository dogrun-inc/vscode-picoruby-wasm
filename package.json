{
  "name": "picoruby-wasm",
  "displayName": "PicoRuby WASM",
  "description": "PicoRuby WASM support for VSCode",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onCommand:picoruby.enable",
    "onCommand:picoruby.disable"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "picoruby",
        "aliases": ["PicoRuby", "picoruby"],
        "extensions": [],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "picoruby",
        "scopeName": "source.picoruby",
        "path": "./syntaxes/picoruby.tmLanguage.json"
      },
      {
        "scopeName": "text.html.picoruby.injection",
        "path": "./syntaxes/picoruby-in-html.tmLanguage.json",
        "injectTo": ["text.html.basic", "text.html.derivative"],
        "embeddedLanguages": {
          "meta.embedded.block.picoruby": "picoruby"
        }
      }
    ],
    "commands": [
      {
        "command": "picoruby.enable",
        "title": "Enable PicoRuby for this workspace (.rb → picoruby)"
      },
      {
        "command": "picoruby.disable",
        "title": "Disable PicoRuby for this workspace (remove .rb mapping)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
